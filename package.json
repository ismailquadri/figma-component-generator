{
  "name": "figma-component-generator",
  "version": "1.0.0",
  "description": "Generate React components from Figma designs automatically",
  "main": "cli.js",
  "bin": {
    "generate-component": "./cli.js"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "figma",
    "react",
    "component",
    "generator",
    "design-system",
    "design-tokens",
    "ui-components",
    "cli"
  ],
  "author": "Ismail Quadri <ismailquadri@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ismailquadri/figma-component-generator.git"
  },
  "bugs": {
    "url": "https://github.com/ismailquadri/figma-component-generator/issues"
  },
  "homepage": "https://github.com/ismailquadri/figma-component-generator#readme",
  "files": [
    "cli.js",
    "config.js",
    "figma.js",
    "generator.js",
    "github-generator.js",
    "handoff-generator.js",
    "token-exporter.js",
    "version-manager.js",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "fs-extra": "^11.1.1",
    "inquirer": "^8.2.5"
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "jest": "^30.3.0"
  }
}
